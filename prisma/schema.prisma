generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id                    String   @id @default(uuid())
  title                 String
  description           String
  primaryCategory       String
  subCategory           String
  seoTags               String[]
  sustainabilityFilters String[]

  aiLogs AILog[]

  createdAt DateTime @default(now())
}

model AILog {
  id       String @id @default(uuid())
  prompt   String
  response String

  module Module

  productId String
  product   Product @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())
}

enum Module {
  CATEGORY_AND_TAG_GENERATION
}
